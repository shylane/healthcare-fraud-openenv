{
  manifest_version: "0.1.0",

  // No API keys required — the environment is fully self-contained.
  // Synthetic fraud data is generated from a seed; no external services.
  config_schema: {
    type: "object",
    properties: {},
    required: [],
    additionalProperties: false,
  },

  // The purple agent's A2A endpoint is passed in via the assessment request body.
  // Amber still needs a proxy slot declared so it can wire up the connection.
  slots: {
    proxy: { kind: "a2a", optional: true },
  },

  program: {
    image: "ghcr.io/shylane/healthcare-fraud-openenv-evaluator:latest",
    entrypoint: "python src/server.py --host 0.0.0.0 --port 9009",

    env: {
      PYTHONUNBUFFERED: "1",
    },

    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 9009 },
      ],
    },
  },

  // This agent provides an A2A endpoint (green agent / evaluator role)
  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  exports: { a2a: "a2a" },

  // Default assessment parameters — mirrors the evaluation study configuration.
  // Purple agents are scored on mean_total_reward across episodes.
  metadata: {
    assessment_config: {
      num_episodes: 20,
      claims_per_episode: 100,
      fraud_rate: 0.05,
      seed: 42,
    },
    participant_roles: ["agent"],
  },
}
